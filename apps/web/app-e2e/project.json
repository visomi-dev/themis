{
  "name": "app-e2e",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web/app-e2e/src",
  "implicitDependencies": ["server"],
  "targets": {
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "outputs": ["{workspaceRoot}/dist/.playwright/apps/web/app-e2e"],
      "options": {
        "config": "apps/web/app-e2e/playwright.config.ts",
        "skipInstall": true
      },
      "dependsOn": ["api:build", "app:build", "site:build", "worker:build", "realtime:build", "server:build"]
    }
  }
}
